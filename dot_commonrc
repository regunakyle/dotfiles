# This should be safe to be sourced anywhere

# Point all Docker usage to the Podman socket
export DOCKER_HOST="unix://$XDG_RUNTIME_DIR/podman/podman.sock"

# Uses fd for fzf
export FZF_DEFAULT_COMMAND="fd --type f --strip-cwd-prefix --hidden --follow --exclude .git --color always"
export FZF_DEFAULT_OPTS="--ansi"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# https://github.com/huggingface/pi-llama
# TODO: Figure out why streaming becomes intermittent when using reverse proxy with SSL
export LLAMA_BASE_URL="http://192.168.1.51:8080/v1"

# Load credentials
source ~/.keys

# Useful alias/functions
# https://wiki.archlinux.org/title/Rsync#As_cp/mv_alternative
cpr() {
    rsync --archive -hh --partial --info=stats1,progress2 --modify-window=1 "$@"
}
mvr() {
    rsync --archive -hh --partial --info=stats1,progress2 --modify-window=1 --remove-source-files "$@"
}
ssh-no-verify() {
    ssh -o "StrictHostKeyChecking=no" -o "UserKnownHostsFile=/dev/null" "$@"
}
