{
  "enabled": true,
  "network": {
    "allowLocalBinding": true,
    "allowAllUnixSockets": true,
    "allowedDomains": ["*"],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": ["~"],
    "allowRead": [".", "~/.pi", "~/.local/share/mise/installs/pi"],
    "allowWrite": [".", "~/.pi"],
    "denyWrite": []
  }
}
