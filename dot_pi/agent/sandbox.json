{
  "enabled": true,
  "network": {
    "allowLocalBinding": true,
    "allowAllUnixSockets": true,
    "allowedDomains": ["*"],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": ["~/.ssh", "~/.keys", "~/.aws", "~/.gnupg"],
    "allowRead": [".", "~/.pi"],
    "allowWrite": [".", "/tmp", "~/.pi"],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key"]
  }
}
